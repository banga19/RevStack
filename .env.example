# =============================================================================
# Mapato — Environment Variables (Copy to .env and fill in values)
# =============================================================================
# Copy this file to .env:
#   cp .env.example .env
# Then fill in the values below.
# =============================================================================

# --- Database ---
# SQLite (default for local development, no additional setup required):
DATABASE_URL="file:./dev.db"

# For PostgreSQL (Docker Compose / production), use:
#   docker compose up -d     # PostgreSQL is started automatically
#   cp prisma/schema.postgres.prisma prisma/schema.prisma && prisma generate
# DATABASE_URL="postgresql://mapato:mapato_secret@localhost:5432/mapato"
#
# To switch schema files:
#   pnpm db:use:postgres   # switch to PostgreSQL (for Docker/production)
#   pnpm db:use:sqlite     # switch back to SQLite (for local dev without Docker)

# --- NextAuth ---
# Generate a random string with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars-long"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (Optional — for Google Sign-In) ---
# Get these from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- SMTP / Email (Optional — for welcome emails) ---
# SMTP_HOST="smtp.ethereal.email"
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="false"

# --- OpenAI / LangChain (Required for AI agents: God Mode, RAG, agent memory) ---
# Get key at: https://platform.openai.com/api-keys
# Used by: agent-orchestrator.ts, agent-memory.ts, rag-pipeline.ts
OPENAI_API_KEY=""

# --- WATI.io — WhatsApp Business API (lead qualification, follow-ups) ---
# Get credentials at: https://app.wati.io
# 1. Sign up → Settings → API Settings → Copy API Token & WhatsApp Number ID
# 2. Find your WATI instance URL in Settings → API Docs (e.g. live-mt-server.wati.io)
# Used by: agent-service-bridge.ts (Lead Agent), wati-integration.ts, subscription-followups.ts
# WATI_API_TOKEN=""
# WATI_WHATSAPP_NUMBER_ID=""
# WATI_API_URL="https://live-mt-server.wati.io"  # Override default WATI instance host (host only, without number path)

# --- Make.com — Workflow Automation (lead capture, compliance alerts, reporting) ---
# Get webhook IDs by creating scenarios at: https://www.make.com
# 1. Create a scenario → Add a "Webhook" module → Copy the webhook ID
# 2. Webhook URL format: https://hook.eu1.make.com/{webhook-id}
# Used by: agent-service-bridge.ts (all agents)
# MAKE_LEAD_CAPTURE_WEBHOOK=""
# MAKE_FOLLOWUP_WEBHOOK=""
# MAKE_BOOKING_WEBHOOK=""
# MAKE_NOSHOW_WEBHOOK=""
# MAKE_REPORTING_WEBHOOK=""
# MAKE_COMPLIANCE_WEBHOOK=""

# --- Zoho CRM — Customer Relationship Management ---
# Get credentials at: https://api-console.zoho.com/
# 1. Create "Server-based Application" → Get Client ID & Secret
# 2. Generate OAuth 2.0 refresh token
# 3. Set ZOHO_DOMAIN based on data center (com, eu, com.au, jp, in, cn)
# Used by: agent-service-bridge.ts (Lead, Onboarding, Revenue agents)
# ZOHO_CLIENT_ID=""
# ZOHO_CLIENT_SECRET=""
# ZOHO_REFRESH_TOKEN=""
# ZOHO_DOMAIN="com"

# --- Voiceflow — Conversational AI Chatbot (lead qualification, onboarding) ---
# Get credentials at: https://creator.voiceflow.com
# 1. Create a project → Settings → API Keys → Generate API Key
# 2. Copy Project ID from project URL or settings
# Used by: agent-service-bridge.ts (Lead, Compliance, Onboarding agents)
# VOICEFLOW_API_KEY=""
# VOICEFLOW_PROJECT_ID=""
# VOICEFLOW_VERSION_ID="production"

# --- Sokogate — B2B Trade Platform (suppliers, buyers, escrow, pilot) ---
# Get credentials by contacting: partners@sokogate.com
# Or visit: https://sokogate.com
# Used by: agent-service-bridge.ts (Trade Agent)
# SOKOGATE_API_KEY=""
# SOKOGATE_API_SECRET=""
# SOKOGATE_API_URL="https://api.sokogate.com/v1"

# --- Instantly.ai — Cold Email Outreach Automation ---
# Get credentials at: https://app.instantly.ai
# 1. Sign up → Settings → API → Generate API Key
# Used by: agent-service-bridge.ts (Lead Agent for outreach campaigns)
# INSTANTLY_API_KEY=""
# INSTANTLY_API_URL="https://api.instantly.ai/v1"

# --- QMe — AI Document Processing (compliance, document collection) ---
# Note: QMe runs in simulation mode by default. No API key needed.
# To connect live QMe API:
# QME_API_KEY=""
# QME_API_URL=""

# --- Cloudflare R2 — Object Storage (for call recordings, documents) ---
# Get credentials at: https://dash.cloudflare.com/profile/api-tokens
# 1. Create API Token with R2 edit permissions
# 2. Create R2 bucket in Cloudflare dashboard
# Used by: src/lib/cloudflare/r2.ts
# CLOUDFLARE_ACCOUNT_ID=""
# CLOUDFLARE_R2_ACCESS_KEY_ID=""
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="revstack"
# R2_PUBLIC_URL=""  # Optional: custom domain for R2 objects

# --- Cloudflare Turnstile — Bot Protection ---
# Get credentials at: https://dash.cloudflare.com/profile/api-tokens
# 1. Add Turnstile to your domain
# 2. Create a widget to get site key and secret key
# Used by: src/components/turnstile-widget.tsx, src/lib/cloudflare/turnstile.ts
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# --- Admin Seeding (set to override defaults in `pnpm run setup`) ---
# ADMIN_EMAIL="admin@aibusinessos.com"
# ADMIN_PASSWORD="admin123"  # WARNING: Change this in production!

# --- Flutterwave (Required for M-Pesa, Mobile Money, Card payments) ---
# Get these from: https://dashboard.flutterwave.com/dashboard/settings/apis
#
# Sandbox (test mode):
#   1. Sign up at https://dashboard.flutterwave.com
#   2. Go to Settings → APIs → Toggle to "Sandbox" mode
#   3. Copy the sandbox public key, secret key, and encryption key
#   4. Set webhook to: https://your-domain.com/api/webhooks/flutterwave
#   5. Get webhook hash from Settings → Webhooks
#
# Production (live):
#   1. Toggle to "Live" mode in Flutterwave dashboard
#   2. Copy the live keys (different from sandbox)
#   3. Go live checklist:
#      - Business registration docs submitted
#      - KYC verification completed
#      - Webhook URL configured
#      - Settlement bank account added
#
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
FLUTTERWAVE_ENCRYPTION_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
FLUTTERWAVE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Subscription Plans (KES cents)
NEXT_PUBLIC_STARTER_PRICE=4900      # $49.00 in cents
NEXT_PUBLIC_PRO_PRICE=9900          # $99.00 in cents

# Trial Duration (3 days = 259200 seconds)
TRIAL_DURATION_SECONDS=259200
#
# Dev mode: If no FLW keys are set, the app auto-simulates payments
# (3-second delay, then auto-activates subscription for testing)

# --- Push Notifications (Required for PWA push notifications) ---
# Generate VAPID keys with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@aibusinessos.com"

# --- Cron (Secret for securing cron endpoints) ---
# CRON_SECRET="your-cron-secret-here"

# --- Sentry — Error Tracking (Optional) ---
# Get DSN at: https://sentry.io
# Set both the public (client) and secret (server) versions:
# SENTRY_DSN="https://your-dsn@sentry.io/your-project"
# NEXT_PUBLIC_SENTRY_DSN="https://your-dsn@sentry.io/your-project"
# SENTRY_ENVIRONMENT="production"

# --- Analytics — Event & Usage Tracking (Optional) ---
# Uncomment ONE analytics provider:
#
# Plausible:
# NEXT_PUBLIC_ANALYTICS_PROVIDER="plausible"
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="mapato.app"
#
# Google Analytics 4:
# NEXT_PUBLIC_ANALYTICS_PROVIDER="ga"
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
#
# PostHog:
# NEXT_PUBLIC_ANALYTICS_PROVIDER="posthog"
# NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
#
# Custom endpoint:
# NEXT_PUBLIC_ANALYTICS_PROVIDER="custom"
# NEXT_PUBLIC_ANALYTICS_ENDPOINT="https://your-analytics-endpoint.com/event"

# --- SEO / Verification (Optional — for search engine console tools) ---
# Google Search Console verification code:
# NEXT_PUBLIC_GOOGLE_VERIFICATION=""
#
# Bing Webmaster Tools verification code:
# NEXT_PUBLIC_BING_VERIFICATION=""
#
# Yandex Webmaster verification code:
# NEXT_PUBLIC_YANDEX_VERIFICATION=""
#
# Facebook domain verification (optional):
# NEXT_PUBLIC_FACEBOOK_VERIFICATION=""

# --- Base URL (Used for sitemap and OG images) ---
# NEXT_PUBLIC_BASE_URL="https://mapato.app"

# --- Google Sheets (Optional — admin review export for signups + onboarding) ---
# Service account credentials from: https://console.cloud.google.com/apis/credentials
# Use ONE account for all sheets; switch target workbook with GOOGLE_SHEET_ID.
# Default workbook here is "mapato Admin - Lead".
# GOOGLE_SHEET_ID="1K8lXrDhnBB_5gAH5ENmGvqqeNrCFGbxLThsB6Sx0AAI"
# GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# GOOGLE_PRIVATE_KEY=""
# GOOGLE_SECOND_SHEET_INDEX="0"
# GOOGLE_SECOND_SHEET_NAME="Onboarding"
# Questionnaire-specific sheet override (defaults to GOOGLE_SHEET_ID)
# GOOGLE_QUESTIONNAIRE_SHEET_ID=""
# GOOGLE_QUESTIONNAIRE_FIRST_SHEET_INDEX="0"

# =============================================================================
# Mapato — Environment Variables (Copy to .env and fill in values)
# =============================================================================
# Copy this file to .env:
#   cp .env.example .env
# Then fill in the values below.
# =============================================================================

# --- Database ---
# SQLite (default, no additional setup required):
DATABASE_URL="file:./dev.db"

# For PostgreSQL (production), use:
# DATABASE_URL="postgresql://user:password@localhost:5432/mapato?schema=public"

# --- NextAuth ---
# Generate a random string with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars-long"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (Optional — for Google Sign-In) ---
# Get these from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- SMTP / Email (Optional — for welcome emails) ---
# SMTP_HOST="smtp.ethereal.email"
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="false"

# --- OpenAI / LangChain (Optional — for AI features) ---
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

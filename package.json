    "langchain": "^1.4.2",
    "lucide-react": "^0.468.0",
    "next": "^16.2.7",
    "next-auth": "^4.24.14",
    "nodemailer": "^8.0.10",
    "posthog-js": "^1.379.2",
    "react": "^19.0.0",

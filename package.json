{
  "name": "mapato",
  "version": "1.0.0",
  "description": "Mapato — AI-Powered Revenue Operations for B2B Trading Companies",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "prisma db push && tsx prisma/seed.ts",
    "db:use:sqlite": "cp prisma/schema.sqlite.prisma prisma/schema.prisma && prisma generate",
    "docker:setup": "prisma db push && tsx prisma/seed.ts && tsx prisma/seed-revstack.ts",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:dev-checkout": "playwright test e2e/dev-mode-checkout.spec.ts",
    "test:e2e:docker": "bash scripts/run-e2e.sh",
    "test:e2e:docker:dev": "bash scripts/run-e2e.sh --dev",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",

// =============================================================================
// RevStack / Mapato — Database Schema (SQLite — Default for Local Dev)
//
// SQLite is used by default for local development without Docker.
// For Docker / production, the Dockerfile copies schema.postgres.prisma
// (PostgreSQL) over this file before running prisma generate.
//
// To switch manually:
//   pnpm db:use:postgres   # switch to PostgreSQL
//   pnpm db:use:sqlite     # switch back to SQLite
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Organization — represents a company/workspace (multi-tenant unit)
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("trial") // trial, starter, growth, enterprise

  /** Custom branding for org portal/dashboard */
  branding  String?  // JSON: { primaryColor, logoUrl, faviconUrl, accentColor }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  clients   Client[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  email          String   @unique
  password       String   // hashed with bcryptjs
  role           String   @default("user") // user, admin
  image          String?  // profile image from Google SSO
  termsAccepted  Boolean  @default(false)
  termsAcceptedAt DateTime?
  termsVersion   String?  @default("1.0")

  // Trial & Subscription fields
  trialStartsAt  DateTime? // When the 14-day free trial started
  trialEndsAt    DateTime? // When the trial ends (trialStartsAt + 14 days)
  subscriptionStatus String @default("trial") // trial, active, past_due, canceled, expired
  subscriptionTier String?  // starter, growth, enterprise — based on onboarding
  subscriptionPlan String   @default("monthly") // monthly, yearly
  subscriptionStartsAt DateTime?
  subscriptionEndsAt DateTime?
  phone          String?  // phone number for M-Pesa payments & WhatsApp follow-ups
  billingEmail   String?  // email for invoices (defaults to user email)

  paymentMethods    Json?          // Store tokenized payment methods
  flutterwaveCustomerId String? @unique
  lastLoginAt   DateTime?  // Last login timestamp for retention tracking

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  partner              Partner?  // partner registration (null if not a partner)
  onboardingResponses  OnboardingResponse[]
  preAuthQuestionnaires PreAuthQuestionnaire[]
  clients              Client[]
  koreanTargets        KoreanCorporateTarget[]
  payments             Payment[]
  followUpLogs         FollowUpLog[]
  leads                Lead[]
  retainers            Retainer[]
  invoices             Invoice[]
  subscriptions        Subscription[]
}

// Subscription — recurring subscription tied to a Flutterwave charge
model Subscription {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                    String    // starter, growth, enterprise
  plan                    String    // monthly, yearly
  flutterwaveTxRef        String    @unique
  flutterwaveTxId         Int?      @unique
  amount                  Float
  currency                String
  status                  String    @default("active") // active, past_due, cancelled, expired
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  cancelAtPeriodEnd       Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime @updatedAt
}

// Payment transactions — M-Pesa, Mobile Money, Visa/Mastercard
model Payment {
  id               String   @id @default(cuid())
  userId           String
  amount           Float
  currency         String   @default("USD")
  provider         String   @default("flutterwave") // flutterwave
  paymentMethod    String   // mpesa, mobile_money, card
  flutterwaveTxRef String?  @unique
  flutterwaveTxId  Int?     @unique
  status           String   @default("pending") // pending, success, failed, cancelled
  tier             String?  // starter, growth, enterprise — what they paid for
  plan             String?  // monthly, yearly
  metadata         String?  // JSON: phone number, card details, etc.
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Follow-up log — tracks trial-ending reminder messages sent
model FollowUpLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // email, whatsapp
  stage     String   // day-10, day-13, day-14, d+3, d+7
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stage, type])
}

// Pre-authentication needs assessment - collected BEFORE user signs up
// This helps personalize the experience based on user goals
model PreAuthQuestionnaire {
  id          String   @id @default(cuid())
  tempId      String   @unique // temporary ID used before auth
  userId      String?  // linked after successful authentication

  // What brings you here
  whatBringsYou    String?  // generate-leads, automate-followups, qualify-leads, improve-outreach, scale-ops, reduce-costs, content-marketing, other

  // Business info
  businessType     String?  // solo, small-agency, ecommerce, trading-wholesale, professional-services, other
  industry         String?
  companySize      String?
  role             String?  // founder-ceo, sales-marketing, operations, other

  // Goals & challenges
  primaryGoal      String
  biggestChallenge String?
  servicesInterest String?  // comma-separated list of services

  // Timeline & budget
  timeline         String?  // asap, 1-3-months, 3-6-months, exploring
  budgetRange      String?  // under-1000, 1000-2500, 2500-5000, not-sure

  // Source & context
  howDidYouHear    String?

  // Status
  completed        Boolean  @default(false)
  linkedAfterAuth  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model OnboardingResponse {
  id          String   @id @default(cuid())
  userId      String
  // Business info
  businessName    String
  industry        String
  companySize     String?
  // Goals & challenges
  primaryGoal     String
  secondaryGoals  String?
  currentChallenges String?
  // Target audience & services
  targetAudience  String?
  servicesNeeded  String?
  // Budget & timeline
  budgetRange     String?
  timeline        String?
  // How they found us
  referralSource  String?
  // Additional info
  additionalNotes String?
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id        String   @id @default(cuid())
  organizationId String?
  userId    String
  name      String
  company   String
  email     String
  phone     String?
  status    String   @default("lead") // lead, qualified, proposal, active, onboarding, done
  tier      String?  // enterprise, growth, starter
  monthlyRetainer Float?
  setupFee  Float?
  source    String?  // referral, cold-outreach, seo, website
  notes     String?
  // Export Readiness Score (0-100) — aligns with Sokogate ERS framework
  ersScore      Int?
  ersBreakdown  String?  // JSON: { documentation, compliance, exportHistory, capacityVerified }
  // Trade corridor — which international trade route this client targets
  corridor      String?  // china-africa, korea-africa, africa-africa
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipelineActions   PipelineAction[]
  outreachCampaigns OutreachCampaign[]
  products          ClientProduct[]
  complianceRecords ClientCompliance[]
  tradeFinanceApps  TradeFinanceApplication[]
  ersSnapshots      ErsSnapshot[]
  followups         Followup[]
  retainers         Retainer[]
  invoices          Invoice[]
  convertedLead     Lead?     // lead that converted to this client
}

// Products/services a client offers for export/trade — enables B2B matching
model ClientProduct {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  category    String?  // agriculture, manufactured-goods, technology, services
  description String?
  certifications String? // comma-separated: HACCP, Halal, Organic, etc.
  exportVolume String?  // e.g. "5000 kg/month"
  unit        String?   // kg, tons, units, etc.
  pricing     String?   // e.g. "$2.50/kg FOB Mombasa"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  complianceRecords ClientCompliance[]
}

// Compliance and certification tracking for Korean/AfCFTA market access
model ClientCompliance {
  id              String   @id @default(cuid())
  clientId        String
  productId       String?  // optional — can be company-level or product-level
  certificationType String  // haccp, halal, phytosanitary, organic, fda, korean-import, etc.
  status          String   @default("not-started") // not-started, in-progress, obtained, expired
  issuer          String?  // e.g. "KEBS", "Korea FDA", "Halal Authority"
  notes           String?
  appliedAt       DateTime?
  obtainedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client  Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product ClientProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// Trade finance applications — AfDB/AFAWA, Sokogate Pay, Letters of Credit
model TradeFinanceApplication {
  id          String   @id @default(cuid())
  clientId    String
  program     String   // afdb-afawa, sokogate-pay-escrow, letter-of-credit, export-credit, other
  amount      Float?
  currency    String   @default("USD")
  status      String   @default("draft") // draft, submitted, under-review, approved, disbursed, rejected
  appliedAt   DateTime?
  approvedAt  DateTime?
  disbursedAt DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model PipelineAction {
  id          String   @id @default(cuid())
  clientId    String
  type        String   // email-sent, call-held, proposal-sent, demo-done, follow-up
  note        String?
  status      String   @default("pending") // pending, completed, cancelled
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model PlanTask {
  id          String   @id @default(cuid())
  day         Int
  title       String
  description String?
  phase       String   // foundation, anchor, growth, scale
  category    String   // outreach, build, content, admin
  status      String   @default("pending") // pending, in-progress, completed, skipped
  priority    String   @default("medium") // low, medium, high, critical
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

model RevenueEntry {
  id        String   @id @default(cuid())
  date      DateTime
  clientId  String?
  clientName String?
  amount    Float
  type      String   // retainer, setup-fee, performance, referral
  category  String?  // enterprise, growth, starter
  note      String?
  createdAt DateTime @default(now())
}

model OutreachCampaign {
  id         String   @id @default(cuid())
  clientId   String?
  clientName String?
  channel    String   // whatsapp, email, linkedin
  type       String   // cold, warm, follow-up, re-engagement
  status     String   @default("draft") // draft, active, paused, completed
  templateId String?
  subject    String?  // email subject line for single-step campaigns
  messageBody String? // main message body for single-step campaigns
  scheduleType  String? @default("immediate") // immediate, scheduled
  targetCount   Int?     @default(0)
  sentCount  Int      @default(0)
  replyCount Int      @default(0)
  openedCount Int?    @default(0)
  clickedCount Int?   @default(0)
  bounceCount Int?    @default(0)
  bookedCount Int     @default(0)
  convertedToClientName String?
  convertedAt DateTime?
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  steps  CampaignStep[]
}

model CampaignStep {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stepNumber  Int
  channel     String   // whatsapp, email
  subject     String?  // email subject line
  messageBody String   // message content
  delayDays   Int      @default(0) // days after previous step
  status      String   @default("pending") // pending, sent, scheduled, skipped
  sentAt      DateTime?
  openedCount Int?     @default(0)
  replyCount  Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Sequence {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  status          String   @default("draft") // draft, active, paused, archived
  triggerType     String   @default("manual") // manual, lead-added, event-based
  metrics         Json?    // { sent, opened, replied, clicked, booked, converted }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  steps           SequenceStep[]
  prospectRuns    ProspectSequence[]
}

model SequenceStep {
  id            String   @id @default(cuid())
  sequenceId    String
  sequence      Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber    Int
  channel       String   // email, whatsapp, sms, linkedin, call
  type          String   @default("send_message") // send_message, make_call, wait, condition, voicemail
  subject       String?  // email subject
  messageBody   String?  // template content
  callScript    String?  // talking points for call steps
  delayHours    Int      @default(0) // hours after previous step
  condition     Json?    // { field, operator, value } for branching
  status        String   @default("pending") // pending, sent, scheduled, skipped
  metrics       Json?    // { sent, opened, replied, ... }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Prospect {
  id            String   @id @default(cuid())
  organizationId String
  firstName     String?
  lastName      String?
  email         String?
  phone         String?
  whatsapp      String?
  linkedin      String?
  company       String?
  title         String?
  industry      String?
  source        String?  // csv-import, manual, enriched, linkedin
  enrichment    Json?    // { companySize, revenue, techStack, ... }
  sequences     ProspectSequence[]
  activities    ProspectActivity[]
  callRecordings CallRecording[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProspectSequence {
  id            String   @id @default(cuid())
  prospectId    String
  sequenceId    String
  currentStep   Int      @default(0)
  status        String   @default("enrolled") // enrolled, active, completed, paused, unsubscribed
  enrolledAt    DateTime @default(now())
  completedAt   DateTime?
  lastActivityAt DateTime?

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([sequenceId])
}

model ProspectActivity {
  id            String   @id @default(cuid())
  prospectId    String
  prospect       Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  type          String   // email_sent, email_opened, email_clicked, email_replied, whatsapp_sent, call_made, call_answered, note_added
  channel       String
  details       Json?    // { subject, duration, sentiment, ... }
  createdAt     DateTime @default(now())

  @@index([prospectId])
  @@index([createdAt])
}

model CallRecording {
  id              String   @id @default(cuid())
  organizationId  String
  prospectId      String?
  prospect        Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  repId           String?  // User who made the call
  direction       String   // outbound, inbound
  status          String   // completed, missed, voicemail, busy, failed
  duration        Int?     // seconds
  recordingUrl    String?  // R2 storage key
  transcription   String?  // AI-generated transcript
  summary         String?  // AI-generated summary
  sentiment       String?  // positive, neutral, negative
  talkingPoints   Json?    // [{ topic, timestamp, snippet }]
  actionItems     Json?    // [{ action, assignee, dueDate }]
  objections      Json?    // [{ objection, suggestedResponse, handled }]
  coachingScore   Float?   // AI call quality score
  starredSnippets Json?    // [{ startTime, endTime, label }]
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([prospectId])
  @@index([createdAt])
}

model CallSnippet {
  id              String   @id @default(cuid())
  recordingId     String
  startTime       Int      // seconds
  endTime         Int
  label           String?  // e.g., "objection-handled", "great-discovery"
  tags            Json?    // [objection, pricing, demo]
  sharedWith      Json?    // [userId, ...]
  createdAt       DateTime @default(now())
}

model BattleCard {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  triggerKeywords Json     // ["price", "expensive", "competitor", "budget"]
  content         String   // suggested response + talking points
  category        String?  // pricing, competitor, objection, feature
  priority        Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([organizationId])
}

model ContentArticle {
  id           String   @id @default(cuid())
  title        String
  keyword      String?
  description  String?
  status       String   @default("idea") // idea, drafting, scheduled, published
  publishDate  DateTime?
  wordCount    Int?
  url          String?
  views        Int      @default(0)
  leadsGenerated Int   @default(0)
  week         Int?
  month        Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Document {
  id          String   @id @default(cuid())
  filename    String
  title       String
  description String?
  category    String   // plan, pitch, technical, financial, marketing
  pages       Int?
  content     String?
  /** R2 object storage key (if uploaded to Cloudflare R2) */
  storageUrl  String?
  createdAt   DateTime @default(now())
}

// ERS Score snapshots for tracking score history over time
model ErsSnapshot {
  id              String   @id @default(cuid())
  clientId        String
  totalScore      Int
  breakdown       String   // JSON breakdown
  readinessLevel  String   // export-ready, developing, needs-work
  snapshotDate    DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model FinancialSnapshot {
  id        String   @id @default(cuid())
  month     Int
  year      Int      @default(2026)
  revenue   Float    @default(0)
  costs     Float    @default(0)
  profit    Float    @default(0)
  clients   Int      @default(0)
  pipelineValue Float @default(0)
  createdAt DateTime @default(now())
}

// Korean corporate procurement targets — 10 target companies
model KoreanCorporateTarget {
  id        String   @id @default(cuid())
  company   String
  tier      String   // Chaebol Supplier, Trading House, Mid-Sized Manufacturer
  focus     String   // Procurement focus categories
  status    String   @default("Identified") // Identified, Outreach Ready, Contact Made, Warm Lead, Hot Lead
  stage     String   @default("Researching") // Researching, Outreach Ready, Intro Sent, Initial Call, Second Meeting, Demo Scheduled, Proposal, Negotiation, Closed
  contactName  String?
  contactTitle String?
  contactEmail String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// Sokogate Platform Pilot cohorts — 20 African exporters on 3-month free trials
model SokogatePilotCohort {
  id          String   @id @default(cuid())
  name        String   // Cohort 1: Agriculture, etc.
  type        String   // Focus commodity type
  count       Int      @default(5)
  enrolled    Int      @default(0)
  startMonth  String   // Month 1, Month 2, etc.
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("Planning") // Planning, Recruiting, Active, Completed
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  participants SokogatePilotParticipant[]
}

// Individual companies enrolled in a pilot cohort
model SokogatePilotParticipant {
  id          String   @id @default(cuid())
  cohortId    String
  companyName String
  contactName  String?
  contactEmail String?
  country     String?  // Kenya, Tanzania, Uganda, etc.
  commodity   String?  // Primary export commodity
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  status      String   @default("invited") // invited, active, completed, churned
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cohort SokogatePilotCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
}

// ── Partner Network Models ───────────────────────────────────────────

// Partner — registered users in the partner program with referral tracking
model Partner {
  id            String   @id @default(cuid())
  userId        String   @unique
  displayName   String   // public-facing name for partner directory
  referralCode  String   @unique // unique code for tracking referrals (e.g., "MAPATO-JOHN")
  commissionRate Float   @default(0.15) // 15% default, upgraded for reseller/agency
  tier          String   @default("affiliate") // affiliate, reseller, agency
  status        String   @default("active") // active, suspended
  bio           String?  // short bio for partner directory
  website       String?  // partner's website
  companyName   String?
  region        String?  // ke, tz, ug, rw, intl
  phone         String?
  notes         String?
  totalEarned   Float    @default(0)
  totalPaid     Float    @default(0)
  payoutMethod  String?  // mpesa, bank, flutterwave
  payoutDetails String?  // JSON: account details
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals Referral[]

  @@index([referralCode])
  @@index([status])
}

// Referral — tracks each referred user and associated commission
model Referral {
  id               String    @id @default(cuid())
  partnerId        String
  referredUserId   String?   // linked after the referred user signs up
  referredEmail    String?   // email of the referred person (captured before signup)
  referredName     String?   // name of the referred person
  referralCode     String    // the code used when signing up
  status           String    @default("pending") // pending, signed-up, converted, paid
  commissionEarned Float     @default(0)
  convertedAt      DateTime?
  signedUpAt       DateTime?
  expiresAt        DateTime? // referral link expiry (90 days from creation)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([referralCode])
  @@index([status])
  @@index([partnerId])
  @@index([referredUserId])
}

// Admin audit log — tracks who did what and when (grant access, extend trial, etc.)
model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  adminName String?
  action    String   // grant_permanent_access, extend_trial, change_role, etc.
  targetUserId String?
  targetEmail  String?
  details   String?  // JSON metadata about the action
  createdAt DateTime @default(now())
}

// Email subscribers captured from the landing page newsletter form
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?  // landing-page, needs-assessment, other
  createdAt DateTime @default(now())
}

// Korean buyer procurement inquiries — submitted via /korea/buyers registration form
model KoreanBuyerInquiry {
  id                String   @id @default(cuid())
  companyName       String
  contactName       String
  email             String
  phone             String?
  jobTitle          String?
  commodityInterest String?  // Commodities they want to source
  monthlyVolume     String?  // Estimated monthly procurement volume
  additionalRequests String?
  status            String   @default("new") // new, contacted, qualified, converted
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ── RevStack: AI-Powered Revenue Automation Models ──────────────────────

// Lead — tracks incoming prospects through qualification pipeline
model Lead {
  id                 String   @id @default(cuid())
  companyName        String
  contactName        String
  email              String
  phone              String?
  whatsapp           String?
  industry           String?
  country            String?
  status             String   @default("new") // new, qualified, disqualified, converted
  qualificationScore Int?
  qualificationTier  String?   // hot, qualified, lukewarm, cold
  qualificationBreakdown String? // JSON: per-component breakdown details
  notes              String?
  source             String?
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  client             Client?  @relation(fields: [clientId], references: [id]) // populated when lead converts to client
  clientId           String?  @unique
  followups          Followup[]
}

// Retainer — recurring revenue agreements with clients
model Retainer {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String
  amountUsd       Float
  billingCycle    String   @default("monthly") // monthly, quarterly, annual
  status          String   @default("active") // active, paused, cancelled
  startDate       String
  nextBillingDate String?
  notes           String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Followup — scheduled outreach messages for leads/clients
model Followup {
  id          String    @id @default(cuid())
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  channel     String    @default("whatsapp") // whatsapp, email
  messageBody String
  status      String    @default("pending") // pending, sent, replied, skipped
  scheduledAt DateTime  @default(now())
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
}

// Message — cross-channel communication log
model Message {
  id        String   @id @default(cuid())
  channel   String   // whatsapp, email
  to        String
  body      String
  status    String   @default("queued") // queued, sent, failed
  leadId    String?
  clientId  String?
  createdAt DateTime @default(now())
}

// Invoice — auto-generated invoices from active retainers (RevStack operations)
model Invoice {
  id              String    @id @default(cuid())
  retainerId      String?
  retainer        Retainer? @relation(fields: [retainerId], references: [id], onDelete: SetNull)
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceNumber   String    @unique
  amountUsd       Float
  currency        String    @default("USD")
  status          String    @default("draft") // draft, sent, paid, overdue, cancelled
  dueDate         DateTime
  issuedAt        DateTime  @default(now())
  paidAt          DateTime?
  notes           String?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([retainerId])
  @@index([clientId])
  @@index([status])
}

// Activity — audit trail / activity feed entries
model Activity {
  id          String   @id @default(cuid())
  type        String
  description String
  entityType  String?  // lead, client, retainer, followup, message, hermes_run
  entityId    String?
  userId      String?
  createdAt   DateTime @default(now())
}

// AgentInsight — persisted agent memory insights that survive restarts
model AgentInsight {
  id              String   @id @default(cuid())
  agentType       String   // lead, trade, compliance, onboarding, revenue, orchestrator
  title           String
  description     String
  category        String   @default("insight") // pattern, anomaly, optimization, insight, alert
  relevanceScore  Float    @default(0.8)
  metadata        String?  // JSON string — arbitrary metadata
  appliedCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agentType])
  @@index([category])
  @@index([createdAt])
}

// AgentReport — persisted agent performance reports
model AgentReport {
  id              String   @id @default(cuid())
  agentType       String   // lead, trade, compliance, onboarding, revenue, orchestrator
  title           String
  summary         String
  actions         String   // JSON array of { action, result, impact }
  metrics         String   // JSON object of metric key-value pairs
  insightRefs     String   // JSON array of insight IDs referenced
  nextActions     String   // JSON array of suggested next action strings
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime @default(now())

  @@index([agentType])
  @@index([createdAt])
}

// CommunicationLogEntry — persisted Central Brain communication log entries
// Survives server restarts for post-mortem analysis and audit trails
model CommunicationLogEntry {
  id              String    @id @default(cuid())
  entryType       String    // message_sent, message_received, action_executed, action_failed, insight_generated, event, error
  source          String
  summary         String
  details         String?   // JSON string
  durationMs      Int?
  correlationId   String?
  timestamp       DateTime  @default(now())

  @@index([entryType])
  @@index([source])
  @@index([timestamp])
  @@index([correlationId])
}

// HermesRun — tracks AI agent execution runs
model HermesRun {
  id              String    @id @default(cuid())
  taskType        String    // qualify_leads, send_followups, onboard_clients, generate_report, custom
  status          String    @default("pending") // pending, running, completed, failed
  input           String?
  output          String?
  errorMessage    String?
  leadsProcessed  Int?
  messagesQueued  Int?
  userId          String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
}
